# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret

# Public URL of the deployed app (not needed for local development)
# AUTH_URL=https://your-app.vercel.app

# Google OAuth credentials (from Google Cloud Console)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Comma-separated list of emails permitted to sign in
ALLOWED_EMAILS=user@example.com,teammate@example.com

# Comma-separated list of emails that get admin access (automatically included in ALLOWED_EMAILS)
ADMIN_EMAILS=admin@example.com
